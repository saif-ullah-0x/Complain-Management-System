# Database Configuration
# Replace with your actual Neon database connection string
# Get this from your Neon dashboard: https://console.neon.tech/
DATABASE_URL=postgresql://username:password@your-project-name.neon.tech/your-database-name?sslmode=require

# Optional: If you prefer to store Neon API key separately
NEON_API_KEY=your_neon_api_key_here

# Application Configuration
NODE_ENV=development
PORT=5000

# Session Configuration (for production, use a secure random string)
SESSION_SECRET=your-secure-session-secret-here